@startuml
title Verification Separation - Independent FSMs For Changing And Proving

skinparam backgroundColor #F7F1E6
skinparam shadowing false
skinparam dpi 130
skinparam defaultFontName Georgia
skinparam defaultFontSize 14
skinparam TitleFontSize 19
skinparam TitleFontColor #161616
skinparam NoteFontSize 12
skinparam ArrowFontSize 12
skinparam ArrowColor #5E5A53
skinparam state {
  BackgroundColor #F2E9D9
  BorderColor #1D1D1D
  FontColor #161616
  ArrowColor #5E5A53
  StartColor #8C2721
  EndColor #161616
}
skinparam note {
  BackgroundColor #F5EBDD
  BorderColor #8C2721
  FontColor #7B1E1E
}

state "Coordinator" as Coord #E8DDD0

state "Implementation Worker" as Impl {
  state "Plan change" as IPlan
  state "Apply change" as IApply
  state "Self-check\n(build / typecheck)" as ISelf
  state "Report changes" as IReport

  [*] --> IPlan
  IPlan --> IApply
  IApply --> ISelf
  ISelf --> IReport
  IReport --> [*]
}

state "Verification Worker" as Verify {
  state "Read change\nas evidence" as VRead
  state "Run independent\nprobes / tests" as VRun
  state "Contrast with claim" as VContrast
  state "Report proof or\nfailing edges" as VReport

  [*] --> VRead
  VRead --> VRun
  VRun --> VContrast
  VContrast --> VReport
  VReport --> [*]
}

Coord --> Impl : implementation task
Impl --> Coord : "I finished changing it"
Coord --> Verify : verification task\n(fresh context)
Verify --> Coord : "it is (not) correct"

note bottom of Verify
  Verification must not inherit
  the implementation worker's
  context, memory, or claim
  set. Otherwise the system
  mistakes "I finished changing
  it" for "it is now correct."
end note

@enduml
