@startuml
title Claude Code Control Plane - The Model Is One Phase Of A Loop

skinparam backgroundColor #F7F1E6
skinparam shadowing false
skinparam dpi 130
skinparam defaultFontName Georgia
skinparam defaultFontSize 14
skinparam TitleFontSize 19
skinparam TitleFontColor #161616
skinparam NoteFontSize 12
skinparam ArrowFontSize 12
skinparam ArrowColor #5E5A53
skinparam state {
  BackgroundColor #F2E9D9
  BorderColor #1D1D1D
  FontColor #161616
  ArrowColor #5E5A53
  StartColor #8C2721
  EndColor #161616
}
skinparam note {
  BackgroundColor #F5EBDD
  BorderColor #8C2721
  FontColor #7B1E1E
}

state "<b>Session Inputs</b>\n- user turn / interrupt\n- CLAUDE.md + rules\n- persistent + session memory\n- skills catalog\n- hooks config" as Inputs #E8DDD0

state "<b>External World</b>\n- filesystem\n- bash / git\n- MCP / network" as World #F3E6CD

state "<b>Observability Sinks</b>\n- transcript\n- task output\n- analytics\n- compact boundaries" as Sinks #E8DDD0

state "Turn Loop" as Loop {
  state "Intake\nprefetch / budget / snip" as Intake
  state "Stream Model" as Model
  state "Execute Tools" as Tools
  state "Merge Effects" as Merge
  state "Recovery" as Recovery
  state "Stop Hooks" as Stop

  [*] --> Intake
  Intake --> Model : within budget
  Intake --> Recovery : PTL / guard trip
  Model --> Tools : tool_use
  Model --> Merge : plain reply
  Tools --> Merge : results ready
  Tools --> Recovery : failure / interrupt
  Merge --> Intake : follow-up turn
  Merge --> Stop : stable completion
  Recovery --> Intake : compact / retry
  Recovery --> Stop : surface error
  Stop --> [*]
}

Inputs --> Intake : assembled\nper turn
Tools --> World : side effects
World --> Tools : tool_result
Merge --> Sinks : append
Recovery --> Sinks : counters + boundary

note bottom of Loop
  The model is not the center.
  It is one phase inside a loop
  that owns intake, tools,
  recovery, and stop discipline.
end note

@enduml
