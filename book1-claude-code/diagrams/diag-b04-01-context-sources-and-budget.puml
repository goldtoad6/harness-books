@startuml
title Context Budget - Thresholds That Trigger Specific Actions

skinparam backgroundColor #F7F1E6
skinparam shadowing false
skinparam dpi 130
skinparam defaultFontName Georgia
skinparam defaultFontSize 14
skinparam TitleFontSize 19
skinparam TitleFontColor #161616
skinparam NoteFontSize 12
skinparam ArrowFontSize 12
skinparam ArrowColor #5E5A53
skinparam state {
  BackgroundColor #F2E9D9
  BorderColor #1D1D1D
  FontColor #161616
  ArrowColor #5E5A53
  StartColor #8C2721
  EndColor #161616
}
skinparam note {
  BackgroundColor #F5EBDD
  BorderColor #8C2721
  FontColor #7B1E1E
}

state "<b>Sources (consume same budget)</b>\nCLAUDE.md / rules\npersistent memory\nsession memory\nconversation messages\nreinjected tool output" as Sources #E8DDD0

state "Budget State" as Budget {
  state "Healthy\n< warning buffer" as Healthy #EFE6D8
  state "Warning\n>= warning buffer" as Warning #F2E9D9
  state "Autocompact\n>= autocompact threshold" as Auto #F5EBDD
  state "Error Buffer\n>= error buffer" as Err #F5EBDD

  Healthy --> Warning : budget rising
  Warning --> Auto : keeps rising
  Auto --> Err : compact failed
  Warning --> Healthy : snip / microcompact
  Auto --> Healthy : autocompact ok
  Err --> Auto : retry compact
}

state "Actions" as Actions {
  state "snip / microcompact" as Snip
  state "autocompact" as Ac
  state "reactive compact\nor surface PTL" as Reactive
}

Sources --> Healthy : every turn writes here

Warning --> Snip : trigger
Auto --> Ac : trigger
Err --> Reactive : trigger

note right of Budget
  Governance is not about counting
  messages. It is about which
  threshold the combined sources
  have crossed, and what action
  that threshold deterministically
  triggers.
end note

@enduml
