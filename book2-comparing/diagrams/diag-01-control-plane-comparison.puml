@startuml
title Claude Code vs Codex - Assemble-Then-Loop vs Structure-Then-Turn

skinparam backgroundColor transparent
skinparam shadowing false
skinparam dpi 120
skinparam defaultFontName Georgia
skinparam defaultFontSize 14
skinparam TitleFontSize 19
skinparam TitleFontColor #161616
skinparam NoteFontSize 12
skinparam ArrowFontSize 12
skinparam ArrowColor #5E5A53
skinparam state {
  BackgroundColor #F2E9D9
  BorderColor #1D1D1D
  FontColor #161616
  ArrowColor #5E5A53
  StartColor #8C2721
  EndColor #161616
}
skinparam note {
  BackgroundColor #F5EBDD
  BorderColor #8C2721
  FontColor #7B1E1E
}

top to bottom direction

state "<b>Claude Code - assemble then loop</b>" as CC {
  state "Collect inputs\ndefault + append +\nCLAUDE.md + memory +\nskills + hooks" as CC_Inputs #E8DDD0
  state "Assemble prompt\n(every turn)" as CC_Assemble
  state "Query loop\nmodel is one phase" as CC_Loop #EFE6D8
  state "Persist + analytics" as CC_Sink

  CC_Inputs -right-> CC_Assemble : dynamic
  CC_Assemble -right-> CC_Loop
  CC_Loop -up-> CC_Assemble : next turn\n(re-assemble)
  CC_Loop -right-> CC_Sink : per turn
}

state "<b>Codex - structure then turn</b>" as CX {
  state "Typed inputs\nAGENTS.md fragment /\nskill fragment /\ntool schema /\napproval policy /\nthread options" as CX_Inputs #E8DDD0
  state "Structured instruction\nlayer" as CX_Struct
  state "Thread / turn runtime" as CX_Runtime #EFE6D8
  state "Rollout / state DB /\nhistory" as CX_Records

  CX_Inputs -right-> CX_Struct : typed
  CX_Struct -right-> CX_Runtime
  CX_Runtime -up-> CX_Struct : next turn\n(same thread)
  CX_Runtime -right-> CX_Records : per turn
}

CC -[hidden]-> CX

note bottom of CC
  Behavior lives in the loop.
  Prompt is rebuilt each turn
  from fresh sources. Design
  lever: the sources you allow
  into Assemble decide what
  the agent notices today.
end note

note bottom of CX
  Behavior lives in the thread.
  Each input is a typed object
  with a provenance. Design
  lever: every object is
  independently versioned and
  auditable.
end note

@enduml
