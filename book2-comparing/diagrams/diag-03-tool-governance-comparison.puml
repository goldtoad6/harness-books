@startuml
title Tool Call States - Runtime Scheduling vs Schema+Policy

skinparam backgroundColor transparent
skinparam shadowing false
skinparam dpi 120
skinparam defaultFontName Georgia
skinparam defaultFontSize 14
skinparam TitleFontSize 19
skinparam TitleFontColor #161616
skinparam NoteFontSize 12
skinparam ArrowFontSize 12
skinparam ArrowColor #5E5A53
skinparam state {
  BackgroundColor #F2E9D9
  BorderColor #1D1D1D
  FontColor #161616
  ArrowColor #5E5A53
  StartColor #8C2721
  EndColor #161616
}
skinparam note {
  BackgroundColor #F5EBDD
  BorderColor #8C2721
  FontColor #7B1E1E
}

top to bottom direction

state "<b>Claude Code - runtime scheduling</b>" as CC {
  state "tool_use blocks" as CC_Blocks #E8DDD0
  state "partitionToolCalls" as CC_Part
  state "Concurrency-safe batch" as CC_Conc
  state "Serial batch" as CC_Ser
  state "StreamingToolExecutor\nqueued -> gated ->\nexecuting -> completed ->\nyielded" as CC_Stream #EFE6D8
  state "ask / allow / deny\n+ Bash special rules" as CC_Perm #F5EBDD

  CC_Blocks -right-> CC_Part
  CC_Part -right-> CC_Conc : safe
  CC_Part -down-> CC_Ser : unsafe
  CC_Conc -down-> CC_Stream
  CC_Ser -right-> CC_Stream
  CC_Perm -up-> CC_Stream : gate
  CC_Stream -up-> CC_Blocks : yield in order
}

state "<b>Codex - schema + policy</b>" as CX {
  state "Tool call (ToolSpec)" as CX_Call #E8DDD0
  state "Schema validation" as CX_Schema
  state "ExecPolicy evaluation\npolicy / rule / eval" as CX_Policy #EFE6D8
  state "Approval params /\nrequest_permissions" as CX_Approval #F5EBDD
  state "Sandbox / network /\nworkdir bind" as CX_Sandbox
  state "Tool runtime" as CX_Runtime

  CX_Call -right-> CX_Schema
  CX_Schema -right-> CX_Policy
  CX_Policy -down-> CX_Approval : ambiguous
  CX_Approval -up-> CX_Policy : user decision
  CX_Policy -right-> CX_Sandbox : allowed
  CX_Sandbox -down-> CX_Runtime
  CX_Runtime -up-> CX_Call : result
}

CC -[hidden]-> CX

note bottom of CC
  Design lever: decisions about
  concurrency, ordering, interrupt,
  and Bash live in code paths
  shared by every tool.
end note

note bottom of CX
  Design lever: decisions live
  in declarative objects -
  schema, policy, sandbox config -
  that can be swapped without
  touching the runtime.
end note

@enduml
